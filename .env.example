# appEcosystem environment configuration
# Copy to `.env` and fill in real values. NEVER commit a populated .env.

# ---------------------------------------------------------------------------
# REQUIRED IN PRODUCTION
# ---------------------------------------------------------------------------
# Shared HMAC secret for inter-service authentication. Must be identical
# across every project in the ecosystem. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# The services will REFUSE TO START with the default value when
# ECOSYSTEM_ENV is not "dev".
ECOSYSTEM_HMAC_SECRET=

# Deployment environment: "dev" | "staging" | "production".
# Any value other than "dev" enables fail-closed checks (e.g. rejecting the
# default HMAC secret).
ECOSYSTEM_ENV=dev

# ---------------------------------------------------------------------------
# OPTIONAL (defaults shown)
# ---------------------------------------------------------------------------
# Where the registry persists its state.
ECOSYSTEM_REGISTRY_FILE=data/registry.json

# Path to the ecosystem config file.
ECOSYSTEM_CONFIG=ecosystem.yaml

# Health monitor polling interval (seconds) and failure threshold before
# a service is marked unhealthy.
ECOSYSTEM_HEALTH_INTERVAL=30
ECOSYSTEM_MAX_FAILURES=5

# Host/port the registry binds to. Default to loopback for safety; set to
# 0.0.0.0 only when the control plane is firewalled to the local network.
ECOSYSTEM_REGISTRY_HOST=127.0.0.1
ECOSYSTEM_REGISTRY_PORT=8500

# Comma-separated list of allowed CORS origins for the registry.
# Use explicit origins in production; "*" is dev-only.
ECOSYSTEM_CORS_ORIGINS=*

# Port of the cyber-claude-harness security daemon.
ASUSGUARD_PORT=8088
